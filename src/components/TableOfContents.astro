---
// src/components/TableOfContents.astro

---

<aside class="toc-sidebar">
  <h3>文章目录</h3>
  <div id="dynamic-toc-list">
    <p class="no-toc">暂无目录</p>
  </div>
</aside>


<script is:inline>
  
  const debounce = (fn, delay = 50) => {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  };

  
  const scrollTocToActive = () => {
   
    const tocContainer = document.querySelector('.toc-sidebar');
    const activeItem = tocContainer?.querySelector('.toc-active');
    if (!tocContainer || !activeItem) return;

    
    const activeItemTop = activeItem.offsetTop; 
    const tocScrollTop = tocContainer.scrollTop; 
    const tocHeight = tocContainer.clientHeight; 

   
    const isActiveInView = 
      activeItemTop >= tocScrollTop && 
      activeItemTop <= tocScrollTop + tocHeight - activeItem.offsetHeight;

    if (!isActiveInView) {
      
      tocContainer.scrollTo({
        top: activeItemTop - 20,
        behavior: 'smooth'
      });
    }
  };

  
  window.addEventListener('DOMContentLoaded', () => {
    
    window.addEventListener('scroll', debounce(scrollTocToActive));
    
   
    setTimeout(scrollTocToActive, 100);
  });
</script>

<style is:global>
  
  .toc-sidebar {
    width: 300px;
    flex-shrink: 0;
    position: sticky;
    top: 20px;
    align-self: flex-start;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    padding: 20px;
    background: var(--toc-bg, #f9f9f9);
    border-radius: 8px;
    border: 1px solid var(--border-color, #e5e7eb);
    z-index: 10;
    margin-right: 1px;
    transition: transform 0.1s ease;
    
    scroll-behavior: smooth !important;
  }

  
  .toc-sidebar h3 {
    font-size: 18px;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border-color, #e5e7eb);
    color: var(--gray-dark, #111827);
  }

  .toc-list {
    list-style: none;
    padding-left: 0;
  }
  .toc-item {
    margin: 8px 0;
  }
  .toc-sublist {
    list-style: none;
    padding-left: 15px;
    margin-top: 4px;
  }
  .toc-link, .toc-sublink {
    color: var(--gray-dark, #111827);
    text-decoration: none;
    display: block;
  }
  .toc-link {
    font-size: 14px;
    line-height: 1.5;
  }
  .toc-sublink {
    font-size: 13px;
    line-height: 1.4;
    padding: 3px 0;
  }
  .toc-link:hover, .toc-sublink:hover {
    color: #0070f3;
  }
  .toc-link.toc-active, .toc-sublink.toc-active {
    font-weight: bold;
    color: #0070f3;
  }

  .no-toc {
    font-size: 14px;
    color: var(--gray, #6b7280);
    margin: 0;
  }

  html[data-theme="dark"] .toc-sidebar {
    --toc-bg: #262626;
    --border-color: #374151;
    --gray-dark: #e5e7eb;
    --gray: #9ca3af;
  }

  @media (max-width: 767px) {
    .toc-sidebar {
      width: 100%;
      margin-right: 0;
      margin-bottom: 20px;
      position: static;
      max-height: none;
    }
  }
</style>
