
<div id="comments" class="mt-12 pt-8 border-t"></div>

<script is:inline>
  
  document.addEventListener('DOMContentLoaded', () => {

    
    function getTheme() {
      return document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'dark_dimmed'
        : 'light';
    }

    
    function loadGiscus() {
      const container = document.getElementById('comments');
      if (!container) return;

      
      container.innerHTML = '';

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'abeliu1029/Knotcosmos43');
      script.setAttribute('data-repo-id', 'R_kgDOTEc3jw');
      script.setAttribute('data-category', 'Announcements');
      script.setAttribute('data-category-id', 'DIC_kwDOTEc3j84C_14y');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '1');
      script.setAttribute('data-input-position', 'top');
      script.setAttribute('data-theme', getTheme());
      script.setAttribute('data-lang', 'zh-CN');
      script.setAttribute('data-loading', 'lazy');
      script.crossOrigin = 'anonymous';
      script.async = true;

      container.appendChild(script);
    }

  
    loadGiscus();

    
    window.addEventListener('themechange', () => {
      
      loadGiscus();
    });

    
    const observer = new MutationObserver(() => {
      loadGiscus();
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    });

  });
</script>
