---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate || '1970-01-01');
  const dateB = new Date(b.data.pubDate || '1970-01-01');
  return dateB.getTime() - dateA.getTime();
});

// ---- 双语言文章列表 ----
const zhPosts = sortedPosts.filter(p => p.id.endsWith('zh'));
const enPosts = sortedPosts.filter(p => p.id.endsWith('en'));
const latestZh = zhPosts.slice(0, 4);
const latestEn = enPosts.slice(0, 4);

// ---- 分别收集中英文标签 ----
// 中文标签：只从中文文章中收集
const zhTagSet = new Set();
zhPosts.forEach(post => {
  if (post.data.tags && Array.isArray(post.data.tags)) {
    post.data.tags.forEach(tag => zhTagSet.add(tag));
  }
});
const zhTagList = Array.from(zhTagSet).slice(0, 12);

// 英文标签：只从英文文章中收集
const enTagSet = new Set();
enPosts.forEach(post => {
  if (post.data.tags && Array.isArray(post.data.tags)) {
    post.data.tags.forEach(tag => enTagSet.add(tag));
  }
});
const enTagList = Array.from(enTagSet).slice(0, 12);

// ---- 总标签数量（用于统计） ----
const allTags = new Set();
sortedPosts.forEach(post => {
  if (post.data.tags && Array.isArray(post.data.tags)) {
    post.data.tags.forEach(tag => allTags.add(tag));
  }
});
const totalTagCount = allTags.size;

// ---- 精选文章 ----
const featuredPosts = sortedPosts
  .filter(p => p.data.featured === true)
  .slice(0, 3);

// ---- 统计信息 ----
const totalPosts = sortedPosts.length;
const siteStartDate = new Date('2025-01-01');
const daysSince = Math.floor((Date.now() - siteStartDate.getTime()) / (1000 * 60 * 60 * 24));

// ---- 社交链接 ----
const socialLinks = [
  { icon: '知', name: 'Zhihu', url: 'https://www.zhihu.com/people/48-48-8-94-74' },
  { icon: '💻', name: 'GitHub', url: 'https://github.com/abeliu1029' },
  { icon: '📧', name: 'Email', url: 'mailto:knotcosmos@qq.com' },
  { icon: '📝', name: 'RSS', url: '/rss.xml' },
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main class="home-main">
    
    <!-- ========== Hero 区域 ========== -->
    <div class="hero">
      <div class="hero-avatar">
        <img 
          src="./a1.png"  
          alt="个人头像" 
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="hero-content">
        <h1 data-i18n="home.hello">你好，朋友! 👋</h1>
        <p class="hero-desc" data-i18n="home.desc">
          欢迎来到我的个人博客，这里会分享我的学习和生活点滴。
        </p>
      </div>
    </div>

    <!-- ========== 个人简介卡片 ========== -->
    <div class="intro-card">
      <p class="intro-bio" data-i18n="home.bio">
        🚀 全栈开发者 · 热爱开源与技术写作
      </p>
      <div class="social-links">
        {socialLinks.map((link) => (
          <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="social-link"
            aria-label={link.name}
          >
            {link.icon} {link.name}
          </a>
        ))}
      </div>
    </div>

    <!-- ========== 统计信息 ========== -->
    <div class="stats">
      <span class="stat-item">📝 <span class="stat-num">{totalPosts}</span> <span data-i18n="home.statsPosts">篇文章</span></span>
      <span class="stat-divider">·</span>
      <span class="stat-item">⏳ <span class="stat-num">{daysSince}</span> <span data-i18n="home.statsDays">天</span></span>
      <span class="stat-divider">·</span>
      <span class="stat-item">🏷️ <span class="stat-num" id="tag-count-zh">{zhTagList.length}</span><span class="stat-num" id="tag-count-en" style="display:none">{enTagList.length}</span> <span data-i18n="home.statsTags">个标签</span></span>
    </div>

    <!-- ========== 中文标签云 ========== -->
    <div class="tag-cloud" id="tag-cloud-zh">
      <p class="tag-label" data-i18n="home.tags">🏷️ 热门标签</p>
      <div class="tag-list">
        {zhTagList.length > 0 ? (
          zhTagList.map((tag) => (
            <a href={`/tags/zh/${tag}`} class="tag-item">{`#${tag}`}</a>
          ))
        ) : (
          <span class="tag-empty">暂无标签</span>
        )}
      </div>
    </div>

    <!-- ========== 英文标签云 ========== -->
    <div class="tag-cloud" id="tag-cloud-en" style="display:none">
      <p class="tag-label" data-i18n="home.tags">🏷️ Hot Tags</p>
      <div class="tag-list">
        {enTagList.length > 0 ? (
          enTagList.map((tag) => (
            <a href={`/tags/en/${tag}`} class="tag-item">{`#${tag}`}</a>
          ))
        ) : (
          <span class="tag-empty">No tags yet</span>
        )}
      </div>
    </div>

    <!-- ========== 最新文章 ========== -->
    <div class="posts-section">
      <p class="section-label" data-i18n="home.latestPosts">📝 最新博客</p>
      
      <div class="posts-list" data-lang="zh">
        {latestZh.map((post) => (
          <article class="post-item" key={post.id}>
            <a href={`/blog/${post.id}`} class="post-title">
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate}>
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </article>
        ))}
      </div>

      <div class="posts-list" data-lang="en" style="display:none">
        {latestEn.map((post) => (
          <article class="post-item" key={post.id}>
            <a href={`/blog/${post.id}`} class="post-title">
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate}>
              {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </article>
        ))}
      </div>

      <p class="more-link">
        <a href="/blog/" data-i18n="home.more">
          查看全部文章 →
        </a>
      </p>
    </div>

    <!-- ========== 精选文章 ========== -->
    {featuredPosts.length > 0 && (
      <div class="featured-section">
        <p class="section-label" data-i18n="home.featured">⭐ 精选文章</p>
        <div class="featured-list">
          {featuredPosts.map((post) => (
            <div class="featured-item" key={post.id}>
              <a href={`/blog/${post.id}`} class="featured-title">
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="featured-desc">{post.data.description}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

  </main>

  <!-- ========== 客户端脚本：语言切换与内容更新 ========== -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {

      // ---- 语言检测 ----
      const getCurrentLang = () => {
        const cookieLang = document.cookie.split('; ').find(row => row.startsWith('preferred-lang='))?.split('=')[1];
        const localLang = localStorage.getItem('preferred-lang');
        return cookieLang || localLang || 'zh';
      };

      const localLang = getCurrentLang();

      // ---- 同步 cookie 和 localStorage ----
      const cookieLang = document.cookie.split('; ').find(row => row.startsWith('preferred-lang='))?.split('=')[1] || 'zh';
      if (localLang !== cookieLang) {
        document.cookie = `preferred-lang=${localLang}; path=/; max-age=31536000; SameSite=Lax`;
        window.location.reload();
      }

      // ---- 多语言文本映射 ----
      const i18nMap = {
        'zh': {
          'home.hello': '你好，朋友! 👋',
          'home.desc': '欢迎来到我的个人博客，这里会分享我的学习和生活点滴。',
          'home.bio': '🚀 全栈开发者 · 热爱开源与技术写作',
          'home.statsPosts': '篇文章',
          'home.statsDays': '天运行',
          'home.statsTags': '个标签',
          'home.tags': '🏷️ 热门标签',
          'home.latestPosts': '📝 最新博客',
          'home.more': '查看全部文章 →',
          'home.featured': '⭐ 精选文章',
        },
        'en': {
          'home.hello': 'Hello, Friend! 👋',
          'home.desc': 'Welcome to my personal blog, where I share my learning and life moments.',
          'home.bio': '🚀 Full-Stack Developer · Open Source Enthusiast',
          'home.statsPosts': 'Posts',
          'home.statsDays': 'Days Running',
          'home.statsTags': 'Tags',
          'home.tags': '🏷️ Hot Tags',
          'home.latestPosts': '📝 Latest Posts',
          'home.more': 'View All Posts →',
          'home.featured': '⭐ Featured Posts',
        }
      };

      // ---- 切换标签云可见性 ----
      const toggleTagCloud = (lang) => {
        const zhCloud = document.getElementById('tag-cloud-zh');
        const enCloud = document.getElementById('tag-cloud-en');
        const zhCount = document.getElementById('tag-count-zh');
        const enCount = document.getElementById('tag-count-en');

        if (lang === 'zh') {
          if (zhCloud) zhCloud.style.display = '';
          if (enCloud) enCloud.style.display = 'none';
          if (zhCount) zhCount.style.display = '';
          if (enCount) enCount.style.display = 'none';
        } else {
          if (zhCloud) zhCloud.style.display = 'none';
          if (enCloud) enCloud.style.display = '';
          if (zhCount) zhCount.style.display = 'none';
          if (enCount) enCount.style.display = '';
        }
      };

      // ---- 更新所有 data-i18n 文本 ----
      const updateTexts = (lang) => {
        const texts = i18nMap[lang] || i18nMap['zh'];
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          if (texts[key] !== undefined) {
            el.textContent = texts[key];
          }
        });
      };

      // ---- 更新头像 alt ----
      const updateAvatar = (lang) => {
        const avatar = document.querySelector('.hero-avatar img');
        if (avatar) {
          avatar.alt = lang === 'zh' ? '个人头像' : 'Personal Avatar';
        }
      };

      // ---- 切换文章列表可见性 ----
      const togglePosts = (lang) => {
        document.querySelectorAll('.posts-list').forEach(el => {
          const elLang = el.getAttribute('data-lang');
          el.style.display = elLang === lang ? '' : 'none';
        });
      };

      // ---- 首次应用 ----
      updateTexts(localLang);
      toggleTagCloud(localLang);
      togglePosts(localLang);
      updateAvatar(localLang);

      // ---- 监听语言切换按钮 ----
      const langToggleBtn = document.getElementById('lang-toggle-btn');
      if (langToggleBtn) {
        langToggleBtn.addEventListener('click', function() {
          setTimeout(() => window.location.reload(), 50);
        });
      }

      // ---- 监听 language-change 事件 ----
      window.addEventListener('language-change', function() {
        const newLang = getCurrentLang();
        updateTexts(newLang);
        toggleTagCloud(newLang);
        togglePosts(newLang);
        updateAvatar(newLang);
      });
    });
  </script>
</BaseLayout>

<style>
  /* ========== 整体布局 ========== */
  .home-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ========== Hero 区域 ========== */
  .hero {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .hero-avatar {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-secondary);
    border: 2px solid var(--border-color);
    transition: transform 0.2s;
  }

  .hero-avatar:hover {
    transform: scale(1.02);
  }

  .hero-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-content h1 {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  /* ========== 个人简介卡片 ========== */
  .intro-card {
    margin: 0 0 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-secondary);
    border-radius: 14px;
    text-align: center;
    border: 1px solid var(--border-color);
    transition: border-color 0.2s;
  }

  .intro-bio {
    font-size: 1rem;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    font-weight: 500;
  }

  .social-links {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-link {
    padding: 0.3rem 0.9rem;
    border-radius: 20px;
    font-size: 0.85rem;
    background: var(--bg-hover, #f0f0f0);
    color: var(--text-secondary);
    transition: all 0.2s;
    text-decoration: none;
    border: 1px solid transparent;
  }

  .social-link:hover {
    background: var(--accent, #0070f3);
    color: #fff;
    border-color: var(--accent, #0070f3);
    transform: translateY(-1px);
  }

  /* ========== 统计信息 ========== */
  .stats {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
    padding: 0.6rem;
    background: var(--bg-secondary);
    border-radius: 10px;
    border: 1px solid var(--border-color);
    flex-wrap: wrap;
  }

  .stat-item {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }

  .stat-num {
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-divider {
    color: var(--border-color);
    opacity: 0.5;
  }

  /* ========== 标签云 ========== */
  .tag-cloud {
    margin: 0 0 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border-radius: 14px;
    border: 1px solid var(--border-color);
  }

  .tag-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin: 0 0 0.6rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-item {
    font-size: 0.8rem;
    padding: 0.15rem 0.7rem;
    border-radius: 16px;
    background: var(--bg-hover, #f0f0f0);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .tag-item:hover {
    background: var(--accent, #0070f3);
    color: #fff;
    border-color: var(--accent, #0070f3);
    transform: translateY(-1px);
  }

  .tag-empty {
    font-size: 0.85rem;
    color: var(--text-secondary);
    opacity: 0.6;
    padding: 0.2rem 0;
  }

  /* ========== 文章列表 ========== */
  .posts-section {
    margin: 1.5rem 0;
  }

  .section-label {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 0.5rem;
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border-color-light, rgba(0,0,0,0.06));
    transition: padding-left 0.2s;
  }

  .post-item:hover {
    padding-left: 0.4rem;
  }

  .post-title {
    font-size: 1rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .post-title:hover {
    color: var(--accent, #0070f3);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
    margin-left: 1rem;
    opacity: 0.7;
  }

  .more-link {
    text-align: right;
    margin: 0.5rem 0 0;
  }

  .more-link a {
    font-size: 0.9rem;
    color: var(--accent, #0070f3);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .more-link a:hover {
    opacity: 0.7;
  }

  /* ========== 精选文章 ========== */
  .featured-section {
    margin: 1.5rem 0 0;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border-radius: 14px;
    border: 1px solid var(--border-color);
  }

  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .featured-item {
    padding: 0.4rem 0;
  }

  .featured-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .featured-title:hover {
    color: var(--accent, #0070f3);
  }

  .featured-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0.1rem 0 0;
    opacity: 0.8;
  }

  /* ========== 响应式 ========== */
  @media (max-width: 600px) {
    .home-main {
      padding: 1.2rem 0.8rem 2rem;
    }

    .hero {
      gap: 1rem;
      flex-direction: column;
      text-align: center;
    }

    .hero-avatar {
      width: 70px;
      height: 70px;
    }

    .hero-content h1 {
      font-size: 1.5rem;
    }

    .hero-desc {
      font-size: 0.95rem;
    }

    .intro-card {
      padding: 1rem;
    }

    .post-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.1rem;
    }

    .post-date {
      margin-left: 0;
      font-size: 0.75rem;
    }

    .stats {
      font-size: 0.8rem;
      gap: 0.3rem;
    }

    .stat-divider {
      display: none;
    }

    .tag-list {
      gap: 0.3rem;
    }

    .social-links {
      gap: 0.4rem;
    }

    .social-link {
      font-size: 0.75rem;
      padding: 0.2rem 0.6rem;
    }
  }

  /* ========== 暗色模式适配 ========== */
  @media (prefers-color-scheme: dark) {
    .post-item {
      border-bottom-color: rgba(255,255,255,0.06);
    }

    .social-link {
      background: var(--bg-hover, #2a2a2a);
    }
  }
</style>