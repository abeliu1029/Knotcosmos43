---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import avatar from '../assets/a1.png'; // 请确认图片路径，若不存在可改为普通img

// 获取所有文章
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate || '1970-01-01');
  const dateB = new Date(b.data.pubDate || '1970-01-01');
  return dateB.getTime() - dateA.getTime();
});

// 按语言分类
const zhPosts = sortedPosts.filter(p => p.id.endsWith('zh'));
const enPosts = sortedPosts.filter(p => p.id.endsWith('en'));
const latestZh = zhPosts.slice(0, 4);
const latestEn = enPosts.slice(0, 4);

// 标签收集
const zhTagSet = new Set();
zhPosts.forEach(post => {
  if (post.data.tags && Array.isArray(post.data.tags)) {
    post.data.tags.forEach(tag => zhTagSet.add(tag));
  }
});
const zhTagList = Array.from(zhTagSet).slice(0, 12);

const enTagSet = new Set();
enPosts.forEach(post => {
  if (post.data.tags && Array.isArray(post.data.tags)) {
    post.data.tags.forEach(tag => enTagSet.add(tag));
  }
});
const enTagList = Array.from(enTagSet).slice(0, 12);

// 总标签数（统计用）
const allTags = new Set();
sortedPosts.forEach(post => {
  if (post.data.tags && Array.isArray(post.data.tags)) {
    post.data.tags.forEach(tag => allTags.add(tag));
  }
});

// 精选文章
const featuredPosts = sortedPosts
  .filter(p => p.data.featured === true)
  .slice(0, 3);

// 统计信息
const totalPosts = sortedPosts.length;
const siteStartDate = new Date('2025-01-01');
const daysSince = Math.floor((Date.now() - siteStartDate.getTime()) / (1000 * 60 * 60 * 24));

// 社交链接
const socialLinks = [
  { icon: '知', name: 'Zhihu', url: 'https://www.zhihu.com/people/48-48-8-94-74' },
  { icon: '💻', name: 'GitHub', url: 'https://github.com/abeliu1029' },
  { icon: '📧', name: 'Email', url: 'mailto:knotcosmos@qq.com' },
  { icon: '📝', name: 'RSS', url: '/rss.xml' },
];

// 结构化数据
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": SITE_TITLE,
  "description": SITE_DESCRIPTION,
  "url": Astro.url.href,
  "author": { "@type": "Person", "name": "Abel Liu" },
  "dateModified": new Date().toISOString(),
};
---

<BaseLayout 
  title={SITE_TITLE} 
  description={SITE_DESCRIPTION}
  ogImage="https://your-site.com/og-home.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <main class="home-main">
    
    <!-- ========== Hero 区域 ========== -->
    <section class="hero" aria-label="个人简介">
      <div class="hero-avatar">
        <Image 
          src={avatar} 
          alt="个人头像" 
          width={80} 
          height={80} 
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="hero-content">
        <h1 id="hero-title">你好，朋友! 👋</h1>
        <p id="hero-desc" class="hero-desc">欢迎来到我的个人博客，这里会分享我的学习和生活点滴。</p>
      </div>
    </section>

    <!-- ========== 个人简介卡片 ========== -->
    <div class="intro-card">
      <p id="intro-bio" class="intro-bio">🔬 学者 · 理论物理</p>
      <div class="social-links">
        {socialLinks.map((link) => (
          <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="social-link"
            aria-label={link.name}
          >
            {link.icon} {link.name}
          </a>
        ))}
      </div>
      
    </div>

    <!-- ========== 统计信息 ========== -->
    <ul class="stats" role="list">
      <li class="stat-item">📝 <strong class="stat-num">{totalPosts}</strong> <span id="stats-posts-label">篇文章</span></li>
      <li class="stat-divider" aria-hidden="true">·</li>
      <li class="stat-item">⏳ <strong class="stat-num">{daysSince}</strong> <span id="stats-days-label">天运行</span></li>
      <li class="stat-divider" aria-hidden="true">·</li>
      <li class="stat-item">🏷️ 
        <strong class="stat-num" id="tag-count-zh">{zhTagList.length}</strong>
        <strong class="stat-num" id="tag-count-en" style="display:none">{enTagList.length}</strong>
        <span id="stats-tags-label">个标签</span>
      </li>
    </ul>

    <!-- ========== 中文标签云 ========== -->
    <div class="tag-cloud" id="tag-cloud-zh">
      <p class="tag-label">🏷️ 热门标签</p>
      <div class="tag-list">
        {zhTagList.length > 0 ? (
          zhTagList.map((tag) => (
            <a href={`/tags/zh/${tag}`} class="tag-item" rel="tag">{`#${tag}`}</a>
          ))
        ) : (
          <span class="tag-empty">暂无标签</span>
        )}
      </div>
    </div>

    <!-- ========== 英文标签云（默认隐藏） ========== -->
    <div class="tag-cloud" id="tag-cloud-en" style="display:none">
      <p class="tag-label">🏷️ Hot Tags</p>
      <div class="tag-list">
        {enTagList.length > 0 ? (
          enTagList.map((tag) => (
            <a href={`/tags/en/${tag}`} class="tag-item" rel="tag">{`#${tag}`}</a>
          ))
        ) : (
          <span class="tag-empty">No tags yet</span>
        )}
      </div>
    </div>

    <!-- ========== 最新文章 ========== -->
    <section class="posts-section" aria-label="最新博客">
      <p class="section-label" id="posts-section-label">📝 最新博客</p>
      
      <!-- 中文文章列表 -->
      <div class="posts-list" data-lang="zh">
        {latestZh.map((post) => (
          <article class="post-item" key={post.id}>
            <a href={`/blog/${post.id}`} class="post-title">
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate}>
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </article>
        ))}
      </div>

      <!-- 英文文章列表（默认隐藏） -->
      <div class="posts-list" data-lang="en" style="display:none">
        {latestEn.map((post) => (
          <article class="post-item" key={post.id}>
            <a href={`/blog/${post.id}`} class="post-title">
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate}>
              {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </article>
        ))}
      </div>

      <p class="more-link">
        <a href="/blog/" id="more-link">查看全部文章 →</a>
      </p>
    </section>

    <!-- ========== 精选文章 ========== -->
    {featuredPosts.length > 0 && (
      <section class="featured-section" aria-label="精选文章">
        <p class="section-label" id="featured-label">⭐ 精选文章</p>
        <div class="featured-list">
          {featuredPosts.map((post) => (
            <div class="featured-item" key={post.id}>
              <a href={`/blog/${post.id}`} class="featured-title">
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="featured-desc">{post.data.description}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

  </main>

  <!-- ========== 客户端脚本 ========== -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // ---- 获取当前语言 ----
      const getCurrentLang = () => {
        const cookieLang = document.cookie.split('; ').find(row => row.startsWith('preferred-lang='))?.split('=')[1];
        const localLang = localStorage.getItem('preferred-lang');
        return cookieLang || localLang || 'zh';
      };

      // ---- 多语言文本 ----
      const i18nMap = {
        zh: {
          hello: '你好，朋友! 👋',
          desc: '欢迎来到我的个人博客，这里会分享我的学习和生活点滴。',
          bio: '🔬 学者 · 理论物理',
          statsPosts: '篇文章',
          statsDays: '天运行',
          statsTags: '个标签',
          tags: '🏷️ 热门标签',
          latestPosts: '📝 最新博客',
          more: '查看全部文章 →',
          featured: '⭐ 精选文章',
          
        },
        en: {
          hello: 'Hello, Friend! 👋',
          desc: 'Welcome to my personal blog, where I share my learning and life moments.',
          bio: '🔬 Scholar · Theoretical Physics',
          statsPosts: 'Posts',
          statsDays: 'Days Running',
          statsTags: 'Tags',
          tags: '🏷️ Hot Tags',
          latestPosts: '📝 Latest Posts',
          more: 'View All Posts →',
          featured: '⭐ Featured Posts',
          
        }
      };

      // ---- 应用语言 ----
      const applyLanguage = (lang) => {
        const texts = i18nMap[lang] || i18nMap.zh;

        // 更新 Hero
        document.getElementById('hero-title').textContent = texts.hello;
        document.getElementById('hero-desc').textContent = texts.desc;

        // 更新 Bio
        document.getElementById('intro-bio').textContent = texts.bio;

        // 更新统计标签
        document.getElementById('stats-posts-label').textContent = texts.statsPosts;
        document.getElementById('stats-days-label').textContent = texts.statsDays;
        document.getElementById('stats-tags-label').textContent = texts.statsTags;

        // 更新标签云标题（两个都需要更新，但只有一个可见）
        const zhCloud = document.getElementById('tag-cloud-zh');
        const enCloud = document.getElementById('tag-cloud-en');
        if (zhCloud) zhCloud.querySelector('.tag-label').textContent = i18nMap.zh.tags;
        if (enCloud) enCloud.querySelector('.tag-label').textContent = i18nMap.en.tags;

        // 更新文章区域标题
        document.getElementById('posts-section-label').textContent = texts.latestPosts;
        // 更新“查看全部”
        document.getElementById('more-link').textContent = texts.more;

        // 更新精选标题（如果存在）
        const featuredLabel = document.getElementById('featured-label');
        if (featuredLabel) featuredLabel.textContent = texts.featured;

        // 更新切换按钮文字
        const toggleBtn = document.getElementById('lang-toggle-btn');
        if (toggleBtn) toggleBtn.textContent = texts.toggleLang;

        // 更新头像 alt
        const avatarImg = document.querySelector('.hero-avatar img');
        if (avatarImg) {
          avatarImg.alt = lang === 'zh' ? '个人头像' : 'Personal Avatar';
        }

        // ---- 切换显示内容 ----
        // 标签云
        if (zhCloud) zhCloud.style.display = lang === 'zh' ? '' : 'none';
        if (enCloud) enCloud.style.display = lang === 'en' ? '' : 'none';

        // 标签计数
        const zhCount = document.getElementById('tag-count-zh');
        const enCount = document.getElementById('tag-count-en');
        if (zhCount) zhCount.style.display = lang === 'zh' ? '' : 'none';
        if (enCount) enCount.style.display = lang === 'en' ? '' : 'none';

        // 文章列表
        document.querySelectorAll('.posts-list').forEach(el => {
          const elLang = el.getAttribute('data-lang');
          el.style.display = elLang === lang ? '' : 'none';
        });
      };

      // ---- 初始化 ----
      const initialLang = getCurrentLang();
      applyLanguage(initialLang);

      // ---- 监听切换按钮 ----
      document.getElementById('lang-toggle-btn').addEventListener('click', function() {
        const current = getCurrentLang();
        const next = current === 'zh' ? 'en' : 'zh';
        document.cookie = `preferred-lang=${next}; path=/; max-age=31536000; SameSite=Lax`;
        localStorage.setItem('preferred-lang', next);
        applyLanguage(next);
        // 触发自定义事件（若有其他组件监听）
        window.dispatchEvent(new CustomEvent('language-change', { detail: { lang: next } }));
      });

      // ---- 监听外部语言切换事件 ----
      window.addEventListener('language-change', function(e) {
        const lang = e.detail?.lang || getCurrentLang();
        applyLanguage(lang);
      });
    });
  </script>
</BaseLayout>

<style>
  /* 样式与之前相同，略作调整（无需改动） */
  .home-main { max-width:720px; margin:0 auto; padding:2rem 1rem 3rem; animation:fadeIn .4s ease-out; }
  @keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
  .hero{display:flex;align-items:center;gap:1.5rem;margin-bottom:1.5rem}
  .hero-avatar{flex-shrink:0;width:80px;height:80px;border-radius:50%;overflow:hidden;background:var(--bg-secondary);border:2px solid var(--border-color);transition:transform .2s}
  .hero-avatar:hover{transform:scale(1.02)}
  .hero-avatar img{width:100%;height:100%;object-fit:cover}
  .hero-content h1{font-size:1.8rem;font-weight:700;margin:0 0 .25rem;line-height:1.2;color:var(--text-primary)}
  .hero-desc{font-size:1rem;color:var(--text-secondary);margin:0;line-height:1.6}
  .intro-card{margin:0 0 1.5rem;padding:1.25rem 1.5rem;background:var(--bg-secondary);border-radius:14px;text-align:center;border:1px solid var(--border-color)}
  .intro-bio{font-size:1rem;color:var(--text-primary);margin:0 0 .75rem;font-weight:500}
  .social-links{display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap}
  .social-link{padding:.3rem .9rem;border-radius:20px;font-size:.85rem;background:var(--bg-hover,#f0f0f0);color:var(--text-secondary);transition:all .2s;text-decoration:none;border:1px solid transparent}
  .social-link:hover{background:var(--accent,#0070f3);color:#fff;border-color:var(--accent,#0070f3);transform:translateY(-1px)}
  .lang-switch{padding:.3rem 1rem;border-radius:20px;border:1px solid var(--border-color);background:var(--bg-hover,#f0f0f0);color:var(--text-secondary);font-size:.85rem;cursor:pointer;transition:all .2s}
  .lang-switch:hover{background:var(--accent,#0070f3);color:#fff;border-color:var(--accent,#0070f3)}
  .stats{display:flex;gap:.5rem;justify-content:center;font-size:.9rem;color:var(--text-secondary);margin:0 0 1.5rem;padding:.6rem;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border-color);flex-wrap:wrap;list-style:none}
  .stat-item{display:inline-flex;align-items:center;gap:.15rem}
  .stat-num{font-weight:700;color:var(--text-primary)}
  .stat-divider{color:var(--border-color);opacity:.5}
  .tag-cloud{margin:0 0 1.5rem;padding:1rem 1.25rem;background:var(--bg-secondary);border-radius:14px;border:1px solid var(--border-color)}
  .tag-label{font-size:.85rem;font-weight:600;color:var(--text-secondary);margin:0 0 .6rem}
  .tag-list{display:flex;flex-wrap:wrap;gap:.4rem}
  .tag-item{font-size:.8rem;padding:.15rem .7rem;border-radius:16px;background:var(--bg-hover,#f0f0f0);color:var(--text-secondary);text-decoration:none;transition:all .2s;border:1px solid transparent}
  .tag-item:hover{background:var(--accent,#0070f3);color:#fff;border-color:var(--accent,#0070f3);transform:translateY(-1px)}
  .tag-empty{font-size:.85rem;color:var(--text-secondary);opacity:.6;padding:.2rem 0}
  .posts-section{margin:1.5rem 0}
  .section-label{font-size:1.1rem;font-weight:600;color:var(--text-primary);margin:0 0 .75rem}
  .posts-list{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.5rem}
  .post-item{display:flex;justify-content:space-between;align-items:baseline;padding:.5rem 0;border-bottom:1px solid var(--border-color-light,rgba(0,0,0,.06));transition:transform .2s}
  .post-item:hover{transform:translateX(4px)}
  .post-title{font-size:1rem;color:var(--text-primary);text-decoration:none;font-weight:500;transition:color .2s}
  .post-title:hover{color:var(--accent,#0070f3)}
  .post-date{font-size:.8rem;color:var(--text-secondary);white-space:nowrap;margin-left:1rem;opacity:.7}
  .more-link{text-align:right;margin:.5rem 0 0}
  .more-link a{font-size:.9rem;color:var(--accent,#0070f3);text-decoration:none;font-weight:500;transition:opacity .2s}
  .more-link a:hover{opacity:.7}
  .featured-section{margin:1.5rem 0 0;padding:1rem 1.25rem;background:var(--bg-secondary);border-radius:14px;border:1px solid var(--border-color)}
  .featured-list{display:flex;flex-direction:column;gap:.6rem}
  .featured-item{padding:.4rem 0}
  .featured-title{font-size:1rem;font-weight:600;color:var(--text-primary);text-decoration:none;transition:color .2s}
  .featured-title:hover{color:var(--accent,#0070f3)}
  .featured-desc{font-size:.85rem;color:var(--text-secondary);margin:.1rem 0 0;opacity:.8}
  @media(max-width:600px){
    .home-main{padding:1.2rem .8rem 2rem}
    .hero{gap:1rem;flex-direction:column;text-align:center}
    .hero-avatar{width:70px;height:70px}
    .hero-content h1{font-size:1.5rem}
    .hero-desc{font-size:.95rem}
    .intro-card{padding:1rem}
    .post-item{flex-direction:column;align-items:flex-start;gap:.1rem}
    .post-date{margin-left:0;font-size:.75rem}
    .stats{font-size:.8rem;gap:.3rem}
    .stat-divider{display:none}
    .tag-list{gap:.3rem}
    .social-links{gap:.4rem}
    .social-link{font-size:.75rem;padding:.2rem .6rem}
  }
  @media(prefers-color-scheme:dark){
    .post-item{border-bottom-color:rgba(255,255,255,.06)}
    .social-link{background:var(--bg-hover,#2a2a2a)}
  }
  @media(prefers-reduced-motion:reduce){
    .home-main{animation:none}
    .hero-avatar:hover,.post-item:hover,.tag-item:hover,.social-link:hover{transform:none}
  }
</style>