---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// ============================================================
// 1. 生成静态路径（仅从英文文章中收集标签）
// ============================================================
export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // 只取英文文章
  const enPosts = allPosts.filter(p => p.id.endsWith('en'));

  const tagSet = new Set<string>();
  enPosts.forEach((post) => {
    if (post.data.tags && Array.isArray(post.data.tags)) {
      post.data.tags.forEach((tag) => tagSet.add(tag));
    }
  });

  console.log('🏷️ 英文标签:', Array.from(tagSet));

  return Array.from(tagSet).map((tag) => ({
    params: { tag: tag },
    props: { tag },
  }));
}

// ============================================================
// 2. 获取当前页面数据
// ============================================================
const { tag } = Astro.props;
const allPosts = await getCollection('blog');

// 只筛选英文文章，且包含当前标签
const filteredPosts = allPosts.filter(
  (post) =>
    post.id.endsWith('en') &&
    post.data.tags &&
    Array.isArray(post.data.tags) &&
    post.data.tags.some((t) => t === tag)
);

const sortedPosts = filteredPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate || '1970-01-01');
  const dateB = new Date(b.data.pubDate || '1970-01-01');
  return dateB.getTime() - dateA.getTime();
});

const postCount = sortedPosts.length;
const pageTitle = `Tag: ${tag}`;
const pageDescription = `${postCount} posts about "${tag}"`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="tag-page">
    <header class="tag-header">
      <h1># {tag}</h1>
      <p class="tag-count">{postCount} posts</p>
    </header>

    {sortedPosts.length === 0 ? (
      <p class="empty-tag">No posts under this tag</p>
    ) : (
      <ul class="post-list">
        {sortedPosts.map((post) => (
          <li class="post-item" key={post.id}>
            <a href={`/blog/${post.id}`} class="post-link">
              <span class="post-title">{post.data.title}</span>
              <time class="post-date">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    )}

    <p class="back-link">
      <a href="/">← Back to Home</a>
    </p>
  </main>
</BaseLayout>

<style>
  /* 与中文版完全相同，只是文本是英文 */
  .tag-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  .tag-header {
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--border-color, #e5e7eb);
    padding-bottom: 1rem;
  }

  .tag-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: var(--text-primary);
  }

  .tag-count {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color-light, rgba(0, 0, 0, 0.06));
    transition: padding-left 0.2s;
  }

  .post-item:hover {
    padding-left: 0.5rem;
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    text-decoration: none;
    gap: 1rem;
  }

  .post-title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.2s;
  }

  .post-link:hover .post-title {
    color: var(--accent, #0070f3);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
    opacity: 0.7;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0.2rem 0 0;
    opacity: 0.8;
  }

  .empty-tag {
    text-align: center;
    color: var(--text-secondary);
    padding: 3rem 0;
  }

  .back-link {
    text-align: center;
    margin-top: 2rem;
  }

  .back-link a {
    font-size: 0.95rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link a:hover {
    color: var(--accent, #0070f3);
  }

  @media (max-width: 600px) {
    .tag-page {
      padding: 1.2rem 0.8rem 2rem;
    }

    .tag-header h1 {
      font-size: 1.6rem;
    }

    .post-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.1rem;
    }

    .post-date {
      font-size: 0.75rem;
    }
  }

  @media (prefers-color-scheme: dark) {
    .post-item {
      border-bottom-color: rgba(255, 255, 255, 0.06);
    }
  }
</style>